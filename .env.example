# ADIVA Environment Configuration
# Copy this file to .env and fill in your actual values

# ========================
# Required Configuration
# ========================

# Mistral AI API Key (required)
# Get your API key from: https://console.mistral.ai/
MISTRAL_API_KEY=your_mistral_api_key_here

# ========================
# Project Settings
# ========================

PROJECT_NAME=ADIVA
LOG_LEVEL=INFO

# ========================
# Optional Configuration
# ========================

# API Server Settings
API_HOST=0.0.0.0
API_PORT=8000
DEBUG_MODE=False

# Mistral AI Model Settings
MISTRAL_MODEL=mistral-large-latest
MISTRAL_TEMPERATURE=0.7
MISTRAL_MAX_TOKENS=1000

# ========================
# Validation Agent
# ========================

# The Validation Agent reads extracted data from outputs/extracted/
# and saves audit reports to outputs/validated/.
# It uses the same Mistral model configured above.

# CORS — comma-separated list of allowed origins
CORS_ORIGINS=http://localhost:3000,http://localhost:8000

# ========================
# MongoDB
# ========================

# MongoDB connection string (required)
MONGO_URI=mongodb://localhost:27017
# Database name
MONGO_DB_NAME=adiva
